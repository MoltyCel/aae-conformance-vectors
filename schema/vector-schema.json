{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MoltyCel/aae-conformance-vectors/schema/vector-schema.json",
  "title": "AAE Conformance Vector",
  "description": "Schema for a single AAE conformance test vector (draft-kroehl-agentic-trust-aae-00).",
  "type": "object",
  "required": ["id", "name", "description", "section_ref", "verification_mode", "input", "expected", "rationale"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^aae-vector-[0-9]{2}$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "section_ref": {
      "type": "string",
      "pattern": "draft-kroehl-agentic-trust-aae-00"
    },
    "verification_mode": {
      "type": "string",
      "enum": ["runtime", "structural"],
      "description": "How the expected verdict is reached. 'structural' = determined by document-only properties (signature, schema/cty, delegation subset/field-compares/monotonicity/depth/cycle); a document-only verifier reaches the correct verdict. 'runtime' = requires live external state (clock for the §2.4 validity window, revocation lookup, or single-use consumed-id tracking); a document-only verifier would diverge. This axis is verdict DERIVATION, orthogonal to TechSpec v0.9 §17 enforcement (verdict ACTION)."
    },
    "input": {
      "type": "object",
      "required": ["secured_aae", "context"],
      "additionalProperties": false,
      "properties": {
        "secured_aae": {
          "type": "string",
          "description": "JWS in compact serialization (header.payload.signature).",
          "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$"
        },
        "context": {
          "type": "object",
          "required": ["current_time"],
          "properties": {
            "current_time": { "type": "string", "format": "date-time" },
            "requested_action": { "type": "string" },
            "action_context": { "type": "object" },
            "subject_binding": { "type": "object" },
            "consumed_ids": { "type": "array", "items": { "type": "string" } },
            "revocation_responses": { "type": "object" },
            "delegation_chain": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["result"],
      "additionalProperties": false,
      "properties": {
        "result": { "type": "string", "enum": ["ACCEPT", "REJECT"] },
        "verification_step": { "type": "integer", "minimum": 1, "maximum": 9 },
        "rejection_reason": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "result": { "const": "REJECT" } } },
          "then": { "required": ["verification_step", "rejection_reason"] }
        }
      ]
    },
    "rationale": { "type": "string", "minLength": 1 }
  }
}
